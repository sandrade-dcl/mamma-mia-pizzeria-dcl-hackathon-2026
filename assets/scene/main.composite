            }
          },
          "ageRating": {
            "type": "string",
            "serializationType": "optional",
            "optionalJsonSchema": {
              "type": "string",
              "enum": [
                "T",
                "A"
              ],
              "default": "T",
              "serializationType": "enum-string",
              "enumObject": {
                "Teen": "T",
                "Adult": "A"
              }
            }
          },
          "categories": {
            "type": "array",
            "serializationType": "optional",
            "optionalJsonSchema": {
