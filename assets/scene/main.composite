                  "game",
                  "casino",
                  "social",
                  "music",
                  "fashion",
                  "crypto",
                  "education",
                  "shop",
                  "business",
                  "sports"
                ],
                "default": "game",
                "serializationType": "enum-string",
                "enumObject": {
                  "ART": "art",
                  "GAME": "game",
                  "CASINO": "casino",
                  "SOCIAL": "social",
                  "MUSIC": "music",
                  "FASHION": "fashion",
                  "CRYPTO": "crypto",
                  "EDUCATION": "education",
                  "SHOP": "shop",
                  "BUSINESS": "business",
                  "SPORTS": "sports"
                }
              },
              "serializationType": "array"
            }
          },
          "author": {
            "type": "string",
            "serializationType": "optional",
            "optionalJsonSchema": {
              "type": "string",
              "serializationType": "utf8-string"
            }
          },
          "email": {
            "type": "string",
            "serializationType": "optional",
            "optionalJsonSchema": {
              "type": "string",
              "serializationType": "utf8-string"
            }
          },
