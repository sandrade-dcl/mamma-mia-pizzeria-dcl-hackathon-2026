                    "type": "integer",
                    "serializationType": "int32"
                  }
                },
                "transitionMode": {
                  "type": "integer",
                  "serializationType": "optional",
                  "optionalJsonSchema": {
                    "type": "integer",
                    "enum": [
                      0,
