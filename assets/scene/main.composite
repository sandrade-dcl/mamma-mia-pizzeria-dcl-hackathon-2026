                "type": "play_default_emote",
                "jsonPayload": "{\"emote\":\"sittingChair1\"}"
              },
              {
                "name": "Mark as taken",
                "type": "set_state",
                "jsonPayload": "{\"state\":\"Taken\"}"
              },
              {
                "name": "Mark as free",
                "type": "set_state",
                "jsonPayload": "{\"state\":\"Free\"}",
                "allowedInBasicView": true
              },
              {
                "name": "Sit Here",
                "type": "batch",
                "jsonPayload": "{\"actions\":[\"Move here\",\"Mark as taken\",\"Random sit anim\"]}",
                "allowedInBasicView": true
              },
              {
                "name": "Sit anim2",
                "type": "play_default_emote",
                "jsonPayload": "{\"emote\":\"sittingChair2\"}"
              },
              {
                "name": "Random sit anim",
                "type": "random",
                "jsonPayload": "{\"actions\":[\"Sit anim1\",\"Sit anim2\"]}"
              },
              {
                "name": "Print text",
                "type": "show_text",
                "jsonPayload": "{\"text\":\"Seat is taken\",\"hideAfterSeconds\":2,\"font\":0,\"fontSize\":40,\"textAlign\":7}"
              },
              {
                "name": "Hide text",
                "type": "hide_text",
                "jsonPayload": "{}"
              },
              {
                "name": "Show text",
                "type": "batch",
                "jsonPayload": "{\"actions\":[\"Hide text\",\"Print text\"]}"
              }
            ]
          }
        }
      }
    },
